# Discord Bot Token
# Get this from Discord Developer Portal: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Google Cloud Vision API Credentials
# Path to GCP service account JSON key file
# Download from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_APPLICATION_CREDENTIALS=secrets/gcp-service-account.json

# PostgreSQL Database URL
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://username:password@localhost:5432/poor_guy_db
